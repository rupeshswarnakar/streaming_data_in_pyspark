# Overview
This project analyzes car listings to identify good deals and overpriced vehicles using PySpark.

It works in both:
- Batch processing
- Real-time streaming mode

# Features
- Calculate price per mile
- Identify good deals automatically
- Process streaming data in real-time
- Save results for further analysis

# Batch Analysis scripts
from pyspark.sql import SparkSession
from pyspark.sql.functions import col

spark = SparkSession.builder.appName("Car Price Analyzer").getOrCreate()

df = spark.read.csv("data/car_listings.csv", header=True, inferSchema=True)

# Basic rule: price per mile
df = df.withColumn("price_per_mile", col("price") / col("mileage"))

# Categorize deals
df = df.withColumn(
    "deal_type",
    (col("price_per_mile") < 0.08).cast("string")
)

df.show()

df.write.mode("overwrite").parquet("output/batch_result")

# Streaming Analysis scripts:
import uuid

spark = SparkSession.builder.appName("Streaming Car Analyzer").getOrCreate()

df = spark.readStream \
    .option("header", True) \
    .schema("car STRING, price DOUBLE, mileage DOUBLE") \
    .csv("data/")

df = df.withColumn("price_per_mile", col("price") / col("mileage"))

good_deals = df.filter(col("price_per_mile") < 0.08)

def process_batch(batch_df, batch_id):
    print(f"Processing batch {batch_id}")
    batch_df.write.mode("append").json("output/stream/" + str(uuid.uuid4()))

query = good_deals.writeStream \
    .foreachBatch(process_batch) \
    .option("checkpointLocation", "checkpoint/") \
    .start()

query.awaitTermination()
